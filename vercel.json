{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "next build",
  "outputDirectory": "out",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.pak-monitor.com" }],
      "destination": "https://pak-monitor.com/$1",
      "permanent": true
    }
  ]
}
